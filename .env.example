# Google Gemini API key
GEMINI_API_KEY=your_api_key_here
# Optional legacy alias (falls back when GEMINI_API_KEY is unset)
GOOGLE_API_KEY=
# Gemini File Search project + location
GEMINI_PROJECT_ID=your-gcp-project-id-or-number
GEMINI_LOCATION=global

# Optional: カスタムモデル指定
# GEMINI_CHAT_MODEL=models/gemini-1.5-pro
# GEMINI_EMBED_MODEL=models/text-embedding-004
# GEMINI_CONTEXT_CHUNKS=4

# Supabase 接続設定 (任意)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_here
SUPABASE_ANON_KEY=public_anon_key_here
# 静的フロントエンドから利用する場合は NEXT_PUBLIC_* も設定してください
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public_anon_key_here
# Google OAuth リダイレクト URL (例: https://example.com/auth/callback)
SUPABASE_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/callback

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ES2021", "DOM"],
    "typeRoots": ["./types"]
  },
  "include": ["api/**/*.ts", "lib/**/*.ts", "supabase/**/*.ts", "types/**/*.d.ts"]
}

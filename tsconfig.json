{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["@types/node"]
  },
  "include": ["api/**/*.ts", "lib/**/*.ts", "supabase/**/*.ts"]
}
